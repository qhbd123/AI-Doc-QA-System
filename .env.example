# Redis连接信息
REDIS_HOST=localhost  # 连接地址
REDIS_PORT=6379       # 端口号
REDIS_DB=0            # 数据库编号
CACHE_EXPIRE=3600     # 缓存过期时间(单位：秒)

# 默认使用的模型提供商（doubao / deepseek / zhipu）
DEFAULT_MODEL_PROVIDER=doubao

# 豆包配置
DOUBAO_API_KEY=******
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_MODEL=doubao-1-5-pro-32k
